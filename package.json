{
  "name": "ww-web-apps",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint apps/**/*.{js,jsx,ts,tsx} packages/**/*.{js,jsx,ts,tsx}",
    "format": "prettier --write apps/**/*.{js,jsx,ts,tsx,html,css,less,ejs} packages/**/*.{js,jsx,ts,tsx,html,css,less,ejs}",
    "start": "yarn workspaces run start",
    "build": "yarn workspaces run build",
    "test": "yarn workspaces run test",
    "deps:check": "depcheck --ignores=\"@types/node,@types/react,@types/react-dom,typescript\" || (echo '❌ Unused dependencies found! Remove them before committing.' && exit 1)",
    "start:secret-santa": "yarn workspace @ww-web-apps/secret-santa start",
    "build:secret-santa": "yarn workspace @ww-web-apps/secret-santa build",
    "test:secret-santa": "yarn workspace @ww-web-apps/secret-santa test run",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^16.7.13",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.0.1",
    "eslint-plugin-unused-imports": "^2.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^13.0.4",
    "prettier": "2.8.0",
    "typescript": "*"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{html,css,less,ejs}": [
      "prettier --write"
    ]
  }
}
