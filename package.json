{
  "name": "ww-web-apps",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint apps/**/*.{ts,tsx} packages/**/*.{ts,tsx}",
    "format": "prettier --write apps/**/*.{js,jsx,ts,tsx,html,css,less,ejs} packages/**/*.{js,jsx,ts,tsx,html,css,less,ejs}",
    "start": "yarn workspaces run start",
    "build": "yarn workspaces run build",
    "test": "yarn workspaces run test",
    "deps:check": "depcheck || (echo '❌ Unused dependencies found! Remove them before committing.' && exit 1)",
    "start:secret-santa": "yarn workspace @ww-web-apps/secret-santa start",
    "build:secret-santa": "yarn workspace @ww-web-apps/secret-santa build",
    "test:secret-santa": "yarn workspace @ww-web-apps/secret-santa test",
    "start:future-weight": "yarn workspace @ww-web-apps/future-weight start",
    "build:future-weight": "yarn workspace @ww-web-apps/future-weight build",
    "test:future-weight": "yarn workspace @ww-web-apps/future-weight test",
    "start:secret-santa-decrypter": "yarn workspace @ww-web-apps/secret-santa-decrypter start",
    "build:secret-santa-decrypter": "yarn workspace @ww-web-apps/secret-santa-decrypter build",
    "test:secret-santa-decrypter": "yarn workspace @ww-web-apps/secret-santa-decrypter test",
    "start:title-case": "yarn workspace @ww-web-apps/title-case start",
    "build:title-case": "yarn workspace @ww-web-apps/title-case build",
    "test:title-case": "yarn workspace @ww-web-apps/title-case test",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "depcheck": "^1.4.7",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^8.0.0",
    "lint-staged": "^13.0.4",
    "prettier": "2.8.0",
    "react-is": "^19.2.4",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{html,css,less,ejs}": [
      "prettier --write"
    ]
  },
  "depcheck": {
    "ignores": [
      "@babel/core",
      "react-is"
    ]
  }
}
