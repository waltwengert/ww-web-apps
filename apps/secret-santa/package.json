{
    "name": "@ww-web-apps/secret-santa",
    "version": "0.1.0",
    "homepage": "https://waltwengert.github.io/secret-santa",
    "private": true,
    "dependencies": {
        "@fontsource/grandstander": "^5.2.7",
        "@testing-library/jest-dom": "^6.1.4",
        "@testing-library/react": "^16.3.2",
        "@vitejs/plugin-react": "^6.0.1",
        "@ww-web-apps/ui": "workspace:*",
        "@ww-web-apps/utils": "workspace:*",
        "gh-pages": "^6.3.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.2",
        "styled-components": "^6.4.1",
        "vite": "^8.0.10"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@types/jest": "^30.0.0",
        "@types/jest-axe": "^3.5.9",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^4.1.5",
        "jest-axe": "^10.0.0",
        "jsdom": "^29.1.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "scripts": {
        "start": "vite",
        "build": "vite build",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.thresholds.lines=60 --coverage.thresholds.functions=60 --coverage.thresholds.statements=60 --coverage.thresholds.branches=50",
        "preview": "vite preview",
        "predeploy": "yarn build",
        "deploy": "gh-pages -d dist"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
